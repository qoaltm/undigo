# ── Midtrans Configuration ──────────────────────────────────────────────
# Copy this file to .env and fill in your values

# Midtrans Client Key (starts with SB- for sandbox, MA- for production)
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx

# Set to "true" for production (uses app.midtrans.com instead of sandbox)
VITE_MIDTRANS_PRODUCTION=false

# ── Backend API ──────────────────────────────────────────────────────────
# Your backend endpoint that creates a Midtrans Snap transaction token
# This must call Midtrans server-side API with your Server Key (keep it secret!)
VITE_API_BASE_URL=http://localhost:3001

# ── Email Service ────────────────────────────────────────────────────────
# Configure in your backend (.env of your server)
# Recommended: Resend (resend.com) or Nodemailer + Gmail OAuth2
# EMAIL_FROM=halo@undigo.id
# EMAIL_RESEND_KEY=re_xxxxxxxxxxxx
